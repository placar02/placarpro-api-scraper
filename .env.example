# NODE_ENV=production
# PORT=3001

# # Hierarquia de fontes
# # SofaScore e a fonte principal; OGOL e 365Scores enriquecem e validam os dados.
# SCORES_PROVIDER=sofascore
# MATCHES_TIMEZONE=America/Sao_Paulo

# # OGOL
# OGOL_BASE_URL=https://www.ogol.com.br
# OGOL_AGENDA_URL=https://www.ogol.com.br/agenda.php
# OGOL_REQUEST_TIMEOUT_MS=30000
# OGOL_CACHE_TTL_MS=600000
# Use quando o OGOL abrir no seu navegador via VPN/proxy, mas retornar 503 no Playwright.
# VPN de extensao do navegador geralmente NAO afeta o Playwright headless.
# Exemplo: OGOL_PROXY_URL=http://127.0.0.1:8080 ou socks5://127.0.0.1:1080
# OGOL_PROXY_URL=
# OGOL_PROXY_USERNAME=
# OGOL_PROXY_PASSWORD=
# OGOL_HEADLESS=true
# Reduza bloqueios ao enriquecer varias partidas no OGOL.
# OGOL_ANALYSIS_CONCURRENCY=1
# Coleta paginas relacionadas: performance, resumo, H2H, equipes, competicao e jogadores.
# OGOL_DEEP_ENRICHMENT=true
# OGOL_DEEP_PLAYER_LIMIT=22
# OGOL_DEEP_PAGE_LIMIT=50
# OGOL_DEEP_DISK_CACHE_DIR=C:\tmp\placarpro-ogol-rich
# Validade separada para a coleta completa (30 minutos).
# OGOL_DEEP_CACHE_TTL_MS=1800000
# Nunca abra muitos navegadores do OGOL ao mesmo tempo.
# OGOL_DEEP_CONCURRENCY=1
# Reutiliza o Chromium entre tarefas e fecha o processo depois deste tempo ocioso.
# OGOL_BROWSER_IDLE_TIMEOUT_MS=120000
# Coleta complementar quando o SofaScore for o provider principal.
# OGOL_ENRICHMENT_ENABLED=true
# OGOL_ENRICHMENT_CACHE_TTL_MS=900000
# OGOL_ENRICHMENT_MATCH_TIMEOUT_MS=20000
# Reutiliza a inspecao do evento entre selecao e analise.
# PROFILE_INSPECTION_CACHE_TTL_MS=900000
# A primeira coleta profunda pode ultrapassar 30 segundos.
# FULL_DAILY_PROFILE_TIMEOUT_MS=120000
# A rota encerra a selecao antes do timeout de 360s e devolve resultado parcial.
# FULL_DAILY_PROFILE_BUDGET_MS=180000
# Timeouts independentes da inspecao; etapas opcionais falham sem bloquear a analise.
# PROFILE_MATCH_INFO_TIMEOUT_MS=8000
# PROFILE_RECENT_MATCHES_TIMEOUT_MS=10000
# PROFILE_HOME_AWAY_TIMEOUT_MS=10000
# PROFILE_GOALS_TIMEOUT_MS=8000
# PROFILE_ADVANCED_TIMEOUT_MS=8000
# PROFILE_LINEUPS_TIMEOUT_MS=6000
# PROFILE_INCIDENTS_TIMEOUT_MS=6000
# No OGOL, faz coleta profunda apenas para a quantidade final + uma pequena reserva.
# Evita abrir dezenas de paginas para candidatos que nunca seriam retornados.
# FULL_DAILY_PROFILE_CANDIDATE_LIMIT=15
# Tiers, aliases e clubes relevantes ficam centralizados em src/config/championshipPriority.ts.
# Participantes sazonais sao aprendidos automaticamente a partir da agenda coletada.
# O retry da chamada Azure ja ocorre internamente.
# FULL_DAILY_ANALYSIS_TIMEOUT_MS=120000
# FULL_DAILY_ANALYSIS_RETRIES=0
# Politica seletiva. Os minimos por mercado em src/config/decisionPolicy.ts
# nunca sao reduzidos por ANALYSIS_MIN_CONFIDENCE.
# ANALYSIS_MIN_CONFIDENCE=72
# ANALYSIS_MIN_EXPECTED_VALUE=0.05
# Reduz excesso de confianca antes de existir calibracao historica (0.50-0.95).
# ANALYSIS_UNCALIBRATED_SHRINKAGE=0.80
# Sobrescritas opcionais por mercado/competicao. Mantenha vazio para os pesos compativeis atuais.
# ANALYSIS_WEIGHT_OVERRIDES_JSON={"markets":{"goals":{"confidence":{"dataQuality":0.45,"marketEvidence":0.55}}}}
# ANALYSIS_GOALS_MIN_CONFIDENCE=72
# ANALYSIS_WINNER_MIN_CONFIDENCE=74
# ANALYSIS_CORNERS_MIN_CONFIDENCE=74
# ANALYSIS_CARDS_MIN_CONFIDENCE=75
# ANALYSIS_PLAYER_MIN_CONFIDENCE=78
# Quantos dias futuros procurar quando somente o ID da partida for informado.
# OGOL_EVENT_LOOKAHEAD_DAYS=7
# PLAYWRIGHT_BROWSERS_PATH=0

# # AiScore
# # Mantido apenas como provider legado opcional: SCORES_PROVIDER=aiscore
# AISCORE_WEB_URL=https://www.aiscore.com/football
# AISCORE_API_BASE_URL=https://api.aiscore.com/v1/web/api
# AISCORE_LANG=2
# AISCORE_SPORT_ID=1
# AISCORE_TIMEZONE_OFFSET=-03:00
# AISCORE_REQUEST_TIMEOUT_MS=30000

# # 365Scores enrichment
# # Mantido apenas como provider legado opcional: SCORES_PROVIDER=365scores
# # Usado junto com AiScore para enriquecer odds, estatisticas, lineups,
# # incidentes, jogadores, cartoes e dados ao vivo.
# SCORES365_BASE_URL=https://webws.365scores.com/web
# SCORES365_LANG_ID=31
# SCORES365_USER_COUNTRY_ID=21

# # SofaScore enrichment (fonte complementar; nao substitui OGOL/365Scores)
# Enriquece somente partidas selecionadas para analise completa.
# SOFASCORE_ENRICHMENT_ENABLED=true
# SOFASCORE_BASE_URL=https://www.sofascore.com/api/v1
# SOFASCORE_ENRICHMENT_CACHE_TTL_MS=900000
# SOFASCORE_ENRICHMENT_FAILURE_CACHE_TTL_MS=60000
# SOFASCORE_ENRICHMENT_REQUEST_TIMEOUT_MS=8000
# SOFASCORE_ENRICHMENT_BROWSER_FALLBACK=true
# SOFASCORE_ENRICHMENT_BROWSER_TIMEOUT_MS=15000
# SOFASCORE_BROWSER_IDLE_TIMEOUT_MS=120000
# SOFASCORE_ENRICHMENT_CONCURRENCY=5
# SOFASCORE_ENRICHMENT_CIRCUIT_FAILURES=3
# SOFASCORE_ENRICHMENT_CIRCUIT_RESET_MS=300000
# Proxy opcional para a rede do worker. Nao contorne CAPTCHA ou bloqueios de acesso.
# SOFASCORE_PROXY_URL=

# # Odds reais Betano (somente worker local, desligado por padrao)
# # Nao use no Render e nao contorne login, CAPTCHA ou bloqueios da plataforma.
# BETANO_ODDS_ENABLED=false
# BETANO_FOOTBALL_URL=https://www.betano.bet.br/sport/futebol/jogos-de-hoje/
# BETANO_ODDS_HEADLESS=true
# BETANO_ODDS_CACHE_TTL_MS=300000
# BETANO_ODDS_TIMEOUT_MS=45000
# BETANO_ODDS_NETWORK_IDLE_MS=5000
# BETANO_ODDS_MAX_REQUESTS_PER_MINUTE=4
# BETANO_ODDS_CIRCUIT_FAILURES=3
# BETANO_ODDS_CIRCUIT_RESET_MS=900000
# BETANO_BROWSER_IDLE_TIMEOUT_MS=120000
# Odds com timestamp mais antigo que 15 minutos nao entram no calculo de EV.
# ODDS_MAX_AGE_MS=900000

# # Azure OpenAI
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://seu-recurso.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT_NAME=
# Uma requisicao por vez evita rajadas e erros 429.
# AZURE_OPENAI_CONCURRENCY=1
# AZURE_OPENAI_RETRIES=0
# AZURE_OPENAI_RETRY_BASE_MS=2000
# Limita os dados enviados ao modelo para reduzir consumo de TPM.
# AZURE_OPENAI_MAX_INPUT_CHARS=24000
# A IA apenas explica a decisao estatistica; 700 tokens costumam ser suficientes.
# AZURE_OPENAI_EXPLANATION_MAX_TOKENS=400
# AZURE_OPENAI_EXPLANATION_TIMEOUT_MS=10000
# FULL_DAILY_EXPLANATION_TIMEOUT_MS=12000
# Pausa novas chamadas depois que o deployment esgota a cota.
# AZURE_OPENAI_COOLDOWN_MS=300000
# AZURE_OPENAI_CACHE_TTL_MS=900000
# AZURE_OPENAI_TIMEOUT_MS=45000
# Para deployments GPT-5/reasoning, usa /openai/v1 e max_completion_tokens.
# AZURE_OPENAI_REASONING_MODEL=true
# AZURE_OPENAI_REASONING_EFFORT=minimal
# AZURE_OPENAI_API_VERSION=2024-02-15-preview
# Fluxos com varias partidas tambem sao processados sem rajadas.
# ANALYSIS_CONCURRENCY=1
# ANALYSIS_TIMEOUT_MS=180000
# ANALYSIS_RETRIES=1
# ANALYSIS_CACHE_TTL_MS=900000
# Fila em memoria para separar a resposta rapida da coleta completa.
# Use false temporariamente para restaurar o comportamento sincrono legado.
# ANALYSIS_ASYNC_ENABLED=true
# ANALYSIS_JOB_CONCURRENCY=1
# ANALYSIS_JOB_TTL_MS=3600000
# ANALYSIS_JOB_POLL_MS=1500
