# =============================================================================
# PLACARPRO-API-SCRAPER - VARIÁVEIS DE AMBIENTE
# =============================================================================
# Copie este arquivo para .env e preencha os valores.
# NUNCA comita arquivos .env contendo valores reais no repositório.
# =============================================================================

# =============================================================================
# 1. CONFIGURAÇÃO DO SERVIDOR
# =============================================================================

# Ambiente de execução
NODE_ENV=production

# Porta onde o servidor Express escuta
# Scraper normalmente usa porta diferente da API principal
PORT=3001

# Host para vincular o servidor
SCRAPER_HOST=127.0.0.1

# Segredo interno para autenticar requisições da API principal
# Deve ser igual ao SCRAPER_INTERNAL_SECRET da API
# Gere com: openssl rand -base64 32
SCRAPER_INTERNAL_SECRET=SEU_SEGREDO_INTERNO_AQUI

# Domínios permitidos para CORS (separados por vírgula)
SCRAPER_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate limit por minuto
SCRAPER_RATE_LIMIT_PER_MINUTE=120

# Rate limit para análises (mais restritivo)
SCRAPER_ANALYSIS_RATE_LIMIT_PER_MINUTE=20

# Confiar em cabeçalhos de proxy (X-Forwarded-For, etc)
# TRUE: Para produção atrás de nginx/load balancer
# FALSE: Para desenvolvimento local
TRUST_PROXY=false

# =============================================================================
# 2. HIERARQUIA DE FONTES DE DADOS
# =============================================================================

# Provedor principal de dados esportivos
# Opções: sofascore | aiscore | 365scores
# SofaScore é recomendado - usa API protobuf oficial
SCORES_PROVIDER=sofascore

# Timezone para exibir horários dos jogos
# Padrão para Brasil: America/Sao_Paulo
MATCHES_TIMEZONE=America/Sao_Paulo

# =============================================================================
# 3. OGOL (Enriquecimento de Dados)
# =============================================================================

# URL base do OGOL
OGOL_BASE_URL=https://www.ogol.com.br

# URL da agenda de jogos
OGOL_AGENDA_URL=https://www.ogol.com.br/agenda.php

# Timeout para requisições (ms)
OGOL_REQUEST_TIMEOUT_MS=30000

# TTL do cache em ms (10 minutos)
OGOL_CACHE_TTL_MS=600000

# Proxy opcional para绕过 bloqueios
# Exemplos: http://127.0.0.1:8080 ou socks5://127.0.0.1:1080
# Deixe vazio se não usar proxy
OGOL_PROXY_URL=
OGOL_PROXY_USERNAME=
OGOL_PROXY_PASSWORD=

# Executar browser em modo headless
OGOL_HEADLESS=true

# Concorrência na análise OGOL (mantenha 1 para evitar bloqueios)
OGOL_ANALYSIS_CONCURRENCY=1

# =============================================================================
# 4. OGOL - COLETA PROFUNDA (ENRIQUECIMENTO COMPLETO)
# =============================================================================

# Habilita coleta profunda (páginas de performance, H2H, equipes, etc)
OGOL_DEEP_ENRICHMENT=true

# Limite de jogadores por equipe
OGOL_DEEP_PLAYER_LIMIT=22

# Limite de páginas por partida
OGOL_DEEP_PAGE_LIMIT=50

# Diretório para cache em disco (caminho absoluto)
# Exemplo Linux/Mac: /tmp/placarpro-ogol-rich
# Exemplo Windows: C:\tmp\placarpro-ogol-rich
OGOL_DEEP_DISK_CACHE_DIR=/tmp/placarpro-ogol-rich

# TTL do cache profundo (30 minutos)
OGOL_DEEP_CACHE_TTL_MS=1800000

# Concorrência da coleta profunda (sempre 1)
OGOL_DEEP_CONCURRENCY=1

# Timeout do browser ocioso (ms)
OGOL_BROWSER_IDLE_TIMEOUT_MS=120000

# Habilita enriquecimento via OGOL quando SofaScore é provider principal
OGOL_ENRICHMENT_ENABLED=true

# TTL do cache de enriquecimento (15 minutos)
OGOL_ENRICHMENT_CACHE_TTL_MS=900000

# Timeout por partida no enriquecimento
OGOL_ENRICHMENT_MATCH_TIMEOUT_MS=20000

# Cache de inspeção do perfil (reutiliza entre seleção e análise)
PROFILE_INSPECTION_CACHE_TTL_MS=900000

# =============================================================================
# 5. OGOL - TIMEOUTS DE COLETA
# =============================================================================

# Timeout para coleta completa do perfil (primeira execução)
FULL_DAILY_PROFILE_TIMEOUT_MS=120000

# Budget total para perfil (ms) - encerra antes do timeout
FULL_DAILY_PROFILE_BUDGET_MS=180000

# Timeout individual por etapa
PROFILE_MATCH_INFO_TIMEOUT_MS=8000
PROFILE_RECENT_MATCHES_TIMEOUT_MS=10000
PROFILE_HOME_AWAY_TIMEOUT_MS=10000
PROFILE_GOALS_TIMEOUT_MS=8000
PROFILE_ADVANCED_TIMEOUT_MS=8000
PROFILE_LINEUPS_TIMEOUT_MS=6000
PROFILE_INCIDENTS_TIMEOUT_MS=6000

# Limite de candidatos para coleta completa
FULL_DAILY_PROFILE_CANDIDATE_LIMIT=15

# Dias de antecedência para buscar partidas
OGOL_EVENT_LOOKAHEAD_DAYS=7

# =============================================================================
# 6. AISCore (Provider Legado)
# =============================================================================
# Mantido para compatibilidade. SCORES_PROVIDER=aiscore para usar.

AISCORE_WEB_URL=https://www.aiscore.com/football
AISCORE_API_BASE_URL=https://api.aiscore.com/v1/web/api
AISCORE_LANG=2
AISCORE_SPORT_ID=1
AISCORE_TIMEZONE_OFFSET=-03:00
AISCORE_REQUEST_TIMEOUT_MS=30000

# =============================================================================
# 7. 365Scores (Provider Legado)
# =============================================================================
# Mantido para compatibilidade. Usado junto com AiScore.

SCORES365_BASE_URL=https://webws.365scores.com/web
SCORES365_LANG_ID=31
SCORES365_USER_COUNTRY_ID=21

# =============================================================================
# 8. SOFASCORE ENRICHMENT
# =============================================================================

# Habilita enriquecimento via SofaScore (dados complementares)
SOFASCORE_ENRICHMENT_ENABLED=true

# URL base da API SofaScore
SOFASCORE_BASE_URL=https://www.sofascore.com/api/v1

# TTL do cache de enriquecimento (15 minutos)
SOFASCORE_ENRICHMENT_CACHE_TTL_MS=900000

# TTL para falhas (1 minuto)
SOFASCORE_ENRICHMENT_FAILURE_CACHE_TTL_MS=60000

# Timeout por requisição
SOFASCORE_ENRICHMENT_REQUEST_TIMEOUT_MS=8000

# Fallback para browser se API falhar
SOFASCORE_ENRICHMENT_BROWSER_FALLBACK=true

# Timeout do browser
SOFASCORE_ENRICHMENT_BROWSER_TIMEOUT_MS=15000

# Timeout do browser ocioso
SOFASCORE_BROWSER_IDLE_TIMEOUT_MS=120000

# Concorrência do enriquecimento
SOFASCORE_ENRICHMENT_CONCURRENCY=5

# Circuit breaker: número de falhas para abrir
SOFASCORE_ENRICHMENT_CIRCUIT_FAILURES=3

# Circuit breaker: tempo para reset (ms)
SOFASCORE_ENRICHMENT_CIRCUIT_RESET_MS=300000

# Proxy opcional para SofaScore
SOFASCORE_PROXY_URL=

# =============================================================================
# 9. BETANO ODDS (WORKER LOCAL APENAS)
# =============================================================================
# NÃO USE NO RENDER - Para coleta local de odds reais da Betano
# NÃO contorne login, CAPTCHA ou bloqueios da plataforma

BETANO_ODDS_ENABLED=false
BETANO_FOOTBALL_URL=https://www.betano.bet.br/sport/futebol/jogos-de-hoje/
BETANO_ODDS_HEADLESS=true
BETANO_ODDS_CACHE_TTL_MS=300000
BETANO_ODDS_TIMEOUT_MS=45000
BETANO_ODDS_NETWORK_IDLE_MS=5000
BETANO_ODDS_MAX_REQUESTS_PER_MINUTE=4
BETANO_ODDS_CIRCUIT_FAILURES=3
BETANO_ODDS_CIRCUIT_RESET_MS=900000
BETANO_BROWSER_IDLE_TIMEOUT_MS=120000

# Odds com mais de 15 minutos são descartadas
ODDS_MAX_AGE_MS=900000

# =============================================================================
# 10. AZURE OPENAI (Análise com IA)
# =============================================================================

# Chave da API Azure OpenAI
AZURE_OPENAI_API_KEY=

# Endpoint do recurso Azure
# Formato: https://{recurso}.openai.azure.com/
AZURE_OPENAI_ENDPOINT=https://seu-recurso.openai.azure.com/

# Nome do deployment no Azure OpenAI Studio
AZURE_OPENAI_DEPLOYMENT_NAME=

# Concorrência de chamadas (mantenha 1 para evitar 429)
AZURE_OPENAI_CONCURRENCY=1

# Número de retries em caso de falha
AZURE_OPENAI_RETRIES=0

# Delay base para retry exponencial (ms)
AZURE_OPENAI_RETRY_BASE_MS=2000

# Máximo de caracteres no input (para reduzir consumo de TPM)
AZURE_OPENAI_MAX_INPUT_CHARS=24000

# Máximo de tokens na explicação gerada
AZURE_OPENAI_EXPLANATION_MAX_TOKENS=400

# Timeout para explicação
AZURE_OPENAI_EXPLANATION_TIMEOUT_MS=10000

# Timeout para explicação completa diária
FULL_DAILY_EXPLANATION_TIMEOUT_MS=12000

# Cooldown após atingir limite de quota (ms)
AZURE_OPENAI_COOLDOWN_MS=300000

# Configurações de circuit breaker
AZURE_OPENAI_CIRCUIT_FAILURES=3
AZURE_OPENAI_CACHE_TTL_MS=900000
AZURE_OPENAI_TIMEOUT_MS=45000

# Para deployments GPT-5 ou reasoning models
AZURE_OPENAI_REASONING_MODEL=true
AZURE_OPENAI_REASONING_EFFORT=minimal

# Versão da API Azure OpenAI
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# =============================================================================
# 11. ANÁLISE DE PARTIDAS
# =============================================================================

# Timeout para análise de uma partida (ms)
FULL_DAILY_ANALYSIS_TIMEOUT_MS=120000

# Número de retries para análise
FULL_DAILY_ANALYSIS_RETRIES=0

# Confiança mínima para recomendar (0-100)
ANALYSIS_MIN_CONFIDENCE=72

# Expected Value mínimo
ANALYSIS_MIN_EXPECTED_VALUE=0.05

# Fator de redução para confiança não calibrada (0.50-0.95)
# Ajuda a evitar excesso de confiança antes de existir calibração histórica
ANALYSIS_UNCALIBRATED_SHRINKAGE=0.80

# Sobrescritas de pesos por mercado (JSON)
# Mantenha vazio para usar pesos padrão
ANALYSIS_WEIGHT_OVERRIDES_JSON={}

# Confiança mínima por mercado
ANALYSIS_GOALS_MIN_CONFIDENCE=72
ANALYSIS_WINNER_MIN_CONFIDENCE=74
ANALYSIS_CORNERS_MIN_CONFIDENCE=74
ANALYSIS_CARDS_MIN_CONFIDENCE=75
ANALYSIS_PLAYER_MIN_CONFIDENCE=78

# Concorrência de análises
ANALYSIS_CONCURRENCY=1

# Timeout para análise
ANALYSIS_TIMEOUT_MS=180000

# Número de retries
ANALYSIS_RETRIES=1

# TTL do cache de análise
ANALYSIS_CACHE_TTL_MS=900000

# =============================================================================
# 12. JOBS ASSÍNCRONOS DE ANÁLISE
# =============================================================================

# Habilita processamento assíncrono
# TRUE: Separa resposta rápida de coleta completa
# FALSE: Comportamento síncrono legado
ANALYSIS_ASYNC_ENABLED=true

# Concorrência de jobs
ANALYSIS_JOB_CONCURRENCY=1

# Tamanho máximo da fila
ANALYSIS_JOB_MAX_QUEUE=50

# Máximo de jobs armazenados
ANALYSIS_JOB_MAX_STORED=500

# TTL dos jobs em ms (1 hora)
ANALYSIS_JOB_TTL_MS=3600000

# Intervalo de poll para jobs (ms)
ANALYSIS_JOB_POLL_MS=1500

# =============================================================================
# 13. PLAYWRIGHT
# =============================================================================

# Caminho para browsers do Playwright
# 0 = usa cache padrão
PLAYWRIGHT_BROWSERS_PATH=0

# Executar testes de integração ao vivo
# FALSE em produção
RUN_LIVE_INTEGRATION_TESTS=false
