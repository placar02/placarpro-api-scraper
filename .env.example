NODE_ENV=production
PORT=3001

# SofaScore
SCORES_PROVIDER=sofascore
SOFASCORE_BASE_URL=https://api.sofascore.com/api/v1
SOFASCORE_IMG_BASE_URL=https://img.sofascore.com/api/v1
# Use quando a SofaScore bloquear o IP atual com 403.
# Exemplo: http://usuario:senha@host:porta
SOFASCORE_PROXY_URL=
# Opcional: chrome, msedge ou chromium. Deixe vazio para tentar automaticamente.
SOFASCORE_BROWSER_CHANNEL=

# 365Scores
# Para usar 365Scores no lugar da SofaScore:
# SCORES_PROVIDER=365scores
SCORES365_BASE_URL=https://webws.365scores.com/web
SCORES365_LANG_ID=31
SCORES365_USER_COUNTRY_ID=21
MATCHES_TIMEZONE=America/Sao_Paulo

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://seu-recurso.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=
