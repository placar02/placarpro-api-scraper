{
  "name": "ApiPlacarPro",
  "version": "0.1.0",
  "description": "API de scraping e normalização de dados esportivos",
  "main": "src/index.ts",
  "repository": "https://github.com/EduardoPH/placarpro-api",
  "author": "EduardoPH",
  "license": "MIT",
  "private": true,
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "nodemon": "^3.1.10",
    "path": "^0.12.7",
    "playwright": "^1.56.0",
    "protobufjs": "^8.6.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tsx": "^4.20.6"
  },
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "node -e \"console.log('No build step required for scraper')\"",
    "postinstall": "playwright install chromium",
    "dev": "nodemon --exec tsx src/index.ts",
    "test": "vitest run",
    "test:routes": "vitest run tests/routes.chain.test.ts --reporter=verbose"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.7.2",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.5",
    "supertest": "^7.1.4",
    "vitest": "^3.2.4"
  }
}
